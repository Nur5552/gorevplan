# Kopyalayın: .env olarak kaydedin ve değerleri doldurun.
BASE_URL=http://localhost:3000
SESSION_SECRET=uzun-rastgele-bir-metin

# İsteğe bağlı veritabanı (varsayılan: localhost root, şifre boş, ogrenci_takip)
 DB_HOST=localhost
 DB_USER=root
 DB_PASSWORD=
 DB_NAME=ogrenci_takip

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Yetkili yönlendirme URI: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub → Settings → Developer settings → OAuth Apps
# Authorization callback URL: http://localhost:3000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# developers.facebook.com → Uygulamanız → Facebook Login → Ayarlar
# Geçerli OAuth yönlendirme URI: http://localhost:3000/auth/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
